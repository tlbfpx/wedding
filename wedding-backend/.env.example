# 数据库
DATABASE_URL=mysql+asyncmy://root:123456@localhost:3306/wedding

# Redis
REDIS_URL=redis://localhost:6379/0

# JWT
JWT_SECRET=your-secret-key-change-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=120
REFRESH_TOKEN_EXPIRE_DAYS=7

# 文件上传
UPLOAD_DIR=uploads
MAX_FILE_SIZE_MB=10

# 应用
APP_NAME=婚庆管理系统
APP_ENV=development
DEBUG=true
SENTRY_DSN=

# CORS（逗号分隔，多个 origins）
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
