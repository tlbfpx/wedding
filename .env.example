# ===========================================
# Wedding Management System - Environment Variables
# ===========================================
# Copy this file to .env and update values for your environment.

# --- Database ---
DATABASE_URL=mysql+asyncmy://root:root@localhost:3306/wedding
MYSQL_ROOT_PASSWORD=root
MYSQL_PORT=3306

# --- Redis ---
REDIS_URL=redis://localhost:6379/0
REDIS_PORT=6379

# --- JWT Authentication ---
JWT_SECRET=your-secret-key-change-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=120
REFRESH_TOKEN_EXPIRE_DAYS=7

# --- File Upload ---
UPLOAD_DIR=uploads
MAX_FILE_SIZE_MB=10

# --- Application ---
APP_NAME=婚庆管理系统
DEBUG=false

# --- Monitoring (optional) ---
# SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id
